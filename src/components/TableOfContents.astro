---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const headings = Astro.props.headings.filter((heading) => heading.depth > 1 && heading.depth <= 3);
---

{headings.length > 0 && (
  <aside class="toc" aria-label="文章目录">
    <strong>目录</strong>
    <ol>
      {headings.map((heading) => (
        <li class={`depth-${heading.depth}`}>
          <a href={`#${heading.slug}`}>{heading.text}</a>
        </li>
      ))}
    </ol>
  </aside>
)}
