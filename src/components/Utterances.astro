---
import { site } from "../site.config";

interface Props {
  title?: string;
  issueTerm?: string;
}

const { title = "评论", issueTerm = "pathname" } = Astro.props;
---

<section class="comments" aria-label={title}>
  <h2>{title}</h2>
  <div id="utterances-root"></div>
  <script is:inline define:vars={{ repo: site.repo, issueTerm }}>
    const mount = document.getElementById("utterances-root");
    if (mount) {
      const script = document.createElement("script");
      script.src = "https://utteranc.es/client.js";
      script.setAttribute("repo", repo);
      script.setAttribute("issue-term", issueTerm);
      script.setAttribute("theme", "preferred-color-scheme");
      script.crossOrigin = "anonymous";
      script.async = true;
      mount.append(script);
    }
  </script>
</section>
