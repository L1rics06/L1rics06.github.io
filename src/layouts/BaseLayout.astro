---
import "../styles/global.css";
import "katex/dist/katex.min.css";
import { site } from "../site.config";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = site.title,
  description = site.description,
  image = site.avatarUrl,
} = Astro.props;

const pageTitle = title === site.title ? site.title : `${title} | ${site.title}`;
const canonical = new URL(Astro.url.pathname, site.url).toString();
const currentPath = Astro.url.pathname;
const navItems = [
  { href: "/", label: "首页" },
  { href: "/about/", label: "关于" },
  { href: "/friends/", label: "友链" },
  { href: "/archive/", label: "归档" },
  { href: "/tags/", label: "标签" },
  { href: "/guestbook/", label: "留言" },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(image, site.url).toString()} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={site.avatarUrl} />
    <link rel="alternate" type="application/rss+xml" title={site.title} href="/rss.xml" />
    <title>{pageTitle}</title>
    <script is:inline>
      const savedTheme = localStorage.getItem("theme");
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      document.documentElement.dataset.theme = savedTheme || (prefersDark ? "dark" : "light");
    </script>
  </head>
  <body>
    <div class="scroll-progress" aria-hidden="true"><span></span></div>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand" href="/" aria-label="首页">
          <img src={site.avatarUrl} alt="" width="44" height="44" />
          <span>
            <strong>{site.title}</strong>
            <small>{site.subtitle}</small>
          </span>
        </a>
        <nav class="site-nav" aria-label="主导航">
          {navItems.map((item) => {
            const isActive = item.href === "/" ? currentPath === "/" : currentPath.startsWith(item.href);
            return <a href={item.href} aria-current={isActive ? "page" : undefined}>{item.label}</a>;
          })}
          <a class="nav-external" href="/rss.xml">RSS</a>
          <a href={site.githubUrl} target="_blank" rel="noreferrer">GitHub</a>
          <button class="theme-toggle" type="button" aria-label="切换至深色主题" title="切换主题">
            <span class="theme-toggle-icon" aria-hidden="true">☾</span>
          </button>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <div class="footer-meta">
          <span>Copyright © {new Date().getFullYear()} {site.author}</span>
          <span>Built with Astro</span>
        </div>
        <a href="/rss.xml">订阅 RSS</a>
      </footer>
    </div>
    <!-- Cloudflare Web Analytics -->
    <script
      is:inline
      type="module"
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "593b839863e34392bde2d7672f35293d"}'
    ></script>
    <!-- End Cloudflare Web Analytics -->
    <script>
      const button = document.querySelector<HTMLButtonElement>(".theme-toggle");
      const icon = document.querySelector<HTMLElement>(".theme-toggle-icon");
      const progress = document.querySelector<HTMLElement>(".scroll-progress span");

      function refreshThemeButton() {
        const isDark = document.documentElement.dataset.theme === "dark";
        button?.setAttribute("aria-label", isDark ? "切换至浅色主题" : "切换至深色主题");
        if (icon) icon.textContent = isDark ? "☀" : "☾";
      }

      button?.addEventListener("click", () => {
        const next = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = next;
        localStorage.setItem("theme", next);
        refreshThemeButton();
      });

      let scrollFrame = 0;
      function updateScrollProgress() {
        scrollFrame = 0;
        if (!progress) return;
        const scrollable = document.documentElement.scrollHeight - window.innerHeight;
        const ratio = scrollable > 0 ? Math.min(window.scrollY / scrollable, 1) : 0;
        progress.style.transform = `scaleX(${ratio})`;
      }

      window.addEventListener("scroll", () => {
        if (!scrollFrame) scrollFrame = window.requestAnimationFrame(updateScrollProgress);
      }, { passive: true });
      window.addEventListener("resize", updateScrollProgress, { passive: true });
      refreshThemeButton();
      updateScrollProgress();
    </script>
  </body>
</html>
