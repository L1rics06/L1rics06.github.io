---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getAllTags, getPosts } from "../../lib/posts";

export async function getStaticPaths() {
  const posts = await getPosts();
  return getAllTags(posts).map(({ tag }) => ({
    params: { tag },
    props: { tag, posts: posts.filter((post) => post.data.tags.includes(tag)) },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`标签：${tag}`} description={`标签 ${tag} 下的文章`}>
  <section class="page-title">
    <h1>标签：{tag}</h1>
    <p>{posts.length} 篇文章</p>
  </section>
  <div class="post-grid">
    {posts.map((post) => <PostCard post={post} />)}
  </div>
</BaseLayout>
